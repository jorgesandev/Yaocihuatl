APP_ENV=development
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
# OpenRouter alternative for DeepSeek:
# LLM_PROVIDER=openrouter
# LLM_MODEL=deepseek/deepseek-chat
# LLM_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=
REDIS_URL=
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=480
RUN_MIGRATIONS_ON_START=true
SEED_DEMO_DATA=true
DEMO_SEED_VERSION=2026-05-initial
LOCAL_EVIDENCE_STORAGE_PATH=/app/storage/evidence
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE="Yaocihuatl Chimalli"
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

TLACHIA_INGESTION_ENABLED=false
TLACHIA_DEMO_MODE=true
TLACHIA_SYNTHETIC_MODE=true
TLACHIA_SYNTHETIC_FIXTURES_PATH=datasets/synthetic/tlachia
TLACHIA_SYNTHETIC_PLATFORMS=facebook,instagram,x,tiktok,reddit
TLACHIA_STORE_RAW_PLATFORM_CONTENT=false
TLACHIA_RETENTION_HOURS=48
TLACHIA_MIN_ALERT_SCORE=50

HASH_VERIFICATION_BASE_URL=
POSTGRES_USER=yaocihuatl
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=yaocihuatl
REDIS_PASSWORD=
# MINIO_ROOT_USER=admin
# MINIO_ROOT_PASSWORD=change-me-in-production
CHIMALLI_DEMO_MODE=true
CHIMALLI_RAG_DOCUMENTS_PATH=../rag_documents
CHIMALLI_RAG_INDEX_PATH=.local/chimalli_rag_index.jsonl
NEXT_PUBLIC_API_URL=http://localhost:8000

# Chimalli LLM / Vision defaults (enabled for demo; disable in production if no external vision provider is authorized)
VISION_LLM_ENABLED=true
VISION_LLM_PROVIDER=openrouter
VISION_LLM_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
EXTRACTION_LLM_PROVIDER=openrouter
EXTRACTION_LLM_MODEL=qwen/qwen3-235b-a22b:free

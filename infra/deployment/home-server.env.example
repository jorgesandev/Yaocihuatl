APP_ENV=demo

FRONTEND_URL=https://yaocihuatl.com
FRONTEND_URLS=https://yaocihuatl.com,https://www.yaocihuatl.com
FRONTEND_PORT=3000

BACKEND_URL=https://api.yaocihuatl.com
BACKEND_PORT=8000
NEXT_PUBLIC_API_URL=https://api.yaocihuatl.com

POSTGRES_USER=yaocihuatl
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=yaocihuatl
REDIS_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

RUN_MIGRATIONS_ON_START=true
SEED_DEMO_DATA=true
DEMO_SEED_VERSION=2026-05-initial
LOCAL_EVIDENCE_STORAGE_PATH=/app/storage/evidence
ACCESS_TOKEN_EXPIRE_MINUTES=480

LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_HTTP_REFERER=https://yaocihuatl.com
OPENROUTER_APP_TITLE=Yaocihuatl Chimalli

CHIMALLI_DEMO_MODE=false
CHIMALLI_RAG_DOCUMENTS_PATH=../rag_documents
CHIMALLI_RAG_INDEX_PATH=.local/chimalli_rag_index.jsonl

yaocihuatl.com, www.yaocihuatl.com {
  encode gzip zstd
  reverse_proxy 127.0.0.1:3000

  header {
    X-Frame-Options "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

api.yaocihuatl.com {
  encode gzip zstd
  reverse_proxy 127.0.0.1:8000

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
